# Copy this file to .env and fill in your values
DATABASE_URL=postgresql://user:password@db:5432/football_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=football_db

# Groq — free LLM for match analysis + chatbot (console.groq.com)
GROQ_API_KEY=

# Optional — for live/upcoming match data (Phase 2+)
API_FOOTBALL_KEY=

MODEL_VERSION=1.0.0
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shared secret between the Next.js proxy and the backend. The proxy injects it
# on every forwarded request; the backend requires it on identity/auth endpoints
# so a direct caller to the backend port cannot spoof X-User-Id. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty in local dev to disable the check (a warning is logged).
INTERNAL_API_SECRET=

# CORS: browsers never call the backend directly (all traffic goes through the
# Next.js proxy), so this defaults to http://localhost:3000. Comma-separate to
# add origins, or set "*" to opt into wide-open (e.g. ad-hoc API testing).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional error tracking. Inert unless set. Get a DSN at sentry.io.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ENV=production

# ── Public URL / auth ─────────────────────────────────────────────────────────
# The public site URL. In production this is the custom domain served via the
# Cloudflare tunnel; locally, http://localhost:3000.
NEXTAUTH_URL=https://aitipster.net
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=https://aitipster.net
ALLOWED_DEV_ORIGINS=aitipster.net,www.aitipster.net

# Google OAuth (optional). Add https://aitipster.net/api/auth/callback/google
# to the client's Authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudflare tunnel ─────────────────────────────────────────────────────────
# No env needed: the tunnel is created via the cloudflared CLI (creds live in
# ~/.cloudflared/) and the launchd plist invokes the binary directly.
# See launchd/CLOUDFLARED_SETUP.md.

# ── umami analytics ───────────────────────────────────────────────────────────
UMAMI_APP_SECRET=change-me-umami-secret
UMAMI_WEBSITE_ID=

# ── Ops (optional) ────────────────────────────────────────────────────────────
# Dead-man's-switch heartbeat URLs (e.g. healthchecks.io). No-op when unset.
HEARTBEAT_URL=
HEARTBEAT_POLL_URL=
# Dynamic-gate change alerts: webhook (Discord/Slack/ntfy) POSTed when a market
# promotes into / demotes out of the suggestable set. No-op when unset (logs only).
GATE_ALERT_URL=
